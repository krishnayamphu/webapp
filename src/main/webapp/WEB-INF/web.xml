<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>Archetype Created Web Application</display-name>
  <context-param>
    <param-name>user</param-name>
    <param-value>admin</param-value>
  </context-param>
  <servlet>
    <servlet-name>config</servlet-name>
    <jsp-file>/jsp/config.jsp</jsp-file>
    <init-param>
      <param-name>company</param-name>
      <param-value>Aptech</param-value>
    </init-param>
  </servlet>
  <servlet>
    <servlet-name>app</servlet-name>
    <jsp-file>/jsp/application.jsp</jsp-file>
  </servlet>
  <servlet>
    <servlet-name>MyServlet</servlet-name>
    <servlet-class>com.ky.servlets.MyServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>PageServlet</servlet-name>
    <servlet-class>com.ky.servlets.PageServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>config</servlet-name>
    <url-pattern>/config</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>app</servlet-name>
    <url-pattern>/app</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>MyServlet</servlet-name>
    <url-pattern>/myservlet</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>PageServlet</servlet-name>
    <url-pattern>/page</url-pattern>
  </servlet-mapping>
</web-app>
